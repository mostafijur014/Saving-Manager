{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A member of the savings group",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the member" },
        "memberId": { "type": "string", "description": "Unique identifier for the member" },
        "phone": { "type": "string", "description": "Phone number for direct calling" },
        "monthlyContribution": { "type": "number", "description": "Agreed monthly savings amount" },
        "totalDeposited": { "type": "number", "description": "Total amount deposited so far" },
        "lastPaymentDate": { "type": "string", "format": "date", "description": "Date of the last deposit" },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Current status of the member" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "memberId", "monthlyContribution", "totalDeposited", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A deposit record",
      "type": "object",
      "properties": {
        "memberId": { "type": "string", "description": "ID of the member who made the deposit" },
        "amount": { "type": "number", "description": "Amount deposited" },
        "date": { "type": "string", "format": "date-time", "description": "When the deposit was made" },
        "month": { "type": "string", "description": "The month this deposit is for (e.g., '2023-10')" }
      },
      "required": ["memberId", "amount", "date", "month"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global interest and group settings",
      "type": "object",
      "properties": {
        "interestAmount": { "type": "number", "description": "Fixed total interest amount to be distributed among members" },
        "duration": { "type": "number", "description": "Duration in months for calculations" },
        "startDate": { "type": "string", "description": "The month the savings group started (e.g., '2023-01')" },
        "announcement": { "type": "string", "description": "Scrolling announcement text" },
        "showAnnouncement": { "type": "boolean", "description": "Whether to show the announcement bar" },
        "announcementSpeed": { "type": "number", "description": "Scrolling speed in seconds (higher is slower)" },
        "tagline1": { "type": "string", "description": "Primary tagline text" },
        "tagline2": { "type": "string", "description": "Secondary tagline text" },
        "showGrowthChart": { "type": "boolean", "description": "Whether to show chart on admin dashboard" },
        "showPublicGrowthChart": { "type": "boolean", "description": "Whether to show chart on public page" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["interestAmount", "duration", "startDate"]
    },
    "EmergencyContact": {
      "title": "Emergency Contact",
      "description": "An emergency contact person",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the contact" },
        "position": { "type": "string", "description": "Job title or relationship" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "order": { "type": "number", "description": "Display order" }
      },
      "required": ["name", "position", "phone"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expenditure record",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Short title of the expense" },
        "detail": { "type": "string", "description": "Detailed description of what the money was spent on" },
        "amount": { "type": "number", "description": "Amount spent" },
        "date": { "type": "string", "format": "date", "description": "Date of the expenditure" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "amount", "date"]
    }
  },
  "firestore": {
    "/members": { "schema": "Member", "description": "Collection of group members" },
    "/transactions": { "schema": "Transaction", "description": "History of all deposits" },
    "/settings": { "schema": "Settings", "description": "Global configuration" },
    "/emergencyContacts": { "schema": "EmergencyContact", "description": "Emergency contact persons" },
    "/expenses": { "schema": "Expense", "description": "Collection of group expenditures" }
  }
}
